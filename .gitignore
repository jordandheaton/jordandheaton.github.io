# Local preview helpers (not needed for the deployed site)
.claude/

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini

# temp preview/export artifacts
_preview_files/
_rpreview*
_preview*

# 3D portfolio: commit only the assets the live site uses; keep the ~83MB of
# draft/source renders (thinkpad/scrub/concept/4K sources) locally, not pushed
assets-3d/*.mp4
!assets-3d/hero-walk-4k.mp4
assets-3d/*.png

# Hub gallery: web-sized images are tracked; keep the full-res originals local only
Images/originals/

# Universe scroller: heavy source media stays local (frames/ ARE tracked — they deploy)
Universe scroller/draft-test/
Universe scroller/media/
Universe scroller/demo/frames/

# myplanBYU: scraper dev artifacts (test PDFs, health reports) stay local
myplanBYU/scraper/data/_*

# myplanBYU: the raw catalog scrape (~69MB) is a LOCAL build input only — the
# deployed site loads the baked js/catalog_data.js, never this. Kept local so
# generate_data.py can rebuild; not tracked (over GitHub's 50MB soft limit).
myplanBYU/scraper/data/catalog.json
